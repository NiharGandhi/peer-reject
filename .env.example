# ==================== PeerReject Environment Configuration ====================

# Node Environment
NODE_ENV=production

# ==================== K2 API Configuration ====================
# Used in lib/k2client.ts for AI/LLM API calls
K2_API_KEY=your_k2_api_key_here
K2_API_URL=https://api.k2.ai/v1

# ==================== OpenTelemetry Configuration ====================
# Used in instrumentation.ts for observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=peer-reject

# ==================== Next.js Configuration ====================
# Disable telemetry in production
NEXT_TELEMETRY_DISABLED=1

# ==================== Optional: Analytics ====================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key

# ==================== Optional: Rate Limiting ====================
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
